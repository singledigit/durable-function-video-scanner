# Ignore TypeScript source files (only include compiled JS)
*.ts
!*.d.ts

# Ignore TypeScript config
tsconfig.json

# Ignore ESLint config
eslint.config.*
.eslintignore

# Ignore node_modules (SAM will bundle dependencies)
node_modules/

# Ignore package lock files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Ignore development files
*.map
*.log
.DS_Store

# Ignore test files
*.test.js
*.spec.js
__tests__/
coverage/

# Ignore documentation
README.md
*.md

# Ignore demo files
index_*.md
